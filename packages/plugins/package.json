{
  "name": "@wrongstack/plugins",
  "version": "0.277.2",
  "description": "Official WrongStack plugin collection — auto-doc, git-autocommit, shell-check, cost-tracker, file-watcher, cron, template-engine, semver-bump, secret-scanner",
  "license": "MIT",
  "author": "ECOSTACK TECHNOLOGY OÜ",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auto-doc": {
      "types": "./dist/auto-doc.d.ts",
      "import": "./dist/auto-doc.js"
    },
    "./git-autocommit": {
      "types": "./dist/git-autocommit.d.ts",
      "import": "./dist/git-autocommit.js"
    },
    "./shell-check": {
      "types": "./dist/shell-check.d.ts",
      "import": "./dist/shell-check.js"
    },
    "./cost-tracker": {
      "types": "./dist/cost-tracker.d.ts",
      "import": "./dist/cost-tracker.js"
    },
    "./file-watcher": {
      "types": "./dist/file-watcher.d.ts",
      "import": "./dist/file-watcher.js"
    },
    "./cron": {
      "types": "./dist/cron.d.ts",
      "import": "./dist/cron.js"
    },
    "./template-engine": {
      "types": "./dist/template-engine.d.ts",
      "import": "./dist/template-engine.js"
    },
    "./semver-bump": {
      "types": "./dist/semver-bump.d.ts",
      "import": "./dist/semver-bump.js"
    },
    "./secret-scanner": {
      "types": "./dist/secret-scanner.d.ts",
      "import": "./dist/secret-scanner.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@wrongstack/core": "workspace:*",
    "@wrongstack/tools": "workspace:*"
  }
}
