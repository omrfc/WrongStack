{
  "name": "@wrongstack/tui",
  "version": "0.155.0",
  "license": "MIT",
  "description": "WrongStack terminal UI: Ink-based interactive renderer with history, pickers, and slash menus.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WrongStack/WrongStack.git",
    "directory": "packages/tui"
  },
  "homepage": "https://github.com/WrongStack/WrongStack#readme",
  "bugs": "https://github.com/WrongStack/WrongStack/issues",
  "author": "ECOSTACK TECHNOLOGY OÜ",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@wrongstack/core": "workspace:*",
    "@wrongstack/runtime": "workspace:*",
    "@wrongstack/tools": "workspace:*",
    "ink": "^7.0.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
