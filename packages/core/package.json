{
  "name": "@wrongstack/core",
  "version": "0.1.4",
  "license": "MIT",
  "description": "WrongStack core: kernel, types, defaults, and shared utilities for the WrongStack CLI agent.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WrongStack/WrongStack.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/WrongStack/WrongStack#readme",
  "bugs": "https://github.com/WrongStack/WrongStack/issues",
  "author": "ECOSTACK TECHNOLOGY OÜ",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "import": "./dist/kernel/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./defaults": {
      "types": "./dist/defaults/index.d.ts",
      "import": "./dist/defaults/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./package.json": "./package.json",
    "./skills/*": "./skills/*"
  },
  "files": ["dist", "skills"],
  "wrongstackApiVersion": "0.1.4",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
