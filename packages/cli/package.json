{
  "name": "@wrongstack/cli",
  "version": "0.9.20",
  "license": "MIT",
  "description": "WrongStack CLI — terminal AI coding agent with provider catalog from models.dev. Provides `wrongstack` and `wstack` binaries.",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "anthropic",
    "openai",
    "gemini",
    "coding-agent",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WrongStack/WrongStack.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/WrongStack/WrongStack#readme",
  "bugs": "https://github.com/WrongStack/WrongStack/issues",
  "author": "ECOSTACK TECHNOLOGY OÜ",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wstack": "./dist/index.js",
    "wrongstack": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@wrongstack/acp": "workspace:*",
    "@wrongstack/core": "workspace:*",
    "@wrongstack/mcp": "workspace:*",
    "@wrongstack/plug-lsp": "workspace:*",
    "@wrongstack/providers": "workspace:*",
    "@wrongstack/runtime": "workspace:*",
    "@wrongstack/telegram": "workspace:*",
    "@wrongstack/tools": "workspace:*",
    "@wrongstack/tui": "workspace:*",
    "@wrongstack/webui": "workspace:*",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
