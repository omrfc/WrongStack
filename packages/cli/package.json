{
  "name": "@wrongstack/cli",
  "version": "0.1.3",
  "license": "MIT",
  "description": "WrongStack CLI — terminal AI coding agent with provider catalog from models.dev. Provides `wrongstack` and `wstack` binaries.",
  "keywords": ["ai", "agent", "cli", "llm", "anthropic", "openai", "gemini", "coding-agent", "mcp"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WrongStack/WrongStack.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/WrongStack/WrongStack#readme",
  "bugs": "https://github.com/WrongStack/WrongStack/issues",
  "author": "ECOSTACK TECHNOLOGY OÜ",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wstack": "./dist/index.js",
    "wrongstack": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@wrongstack/core": "workspace:*",
    "@wrongstack/providers": "workspace:*",
    "@wrongstack/tools": "workspace:*",
    "@wrongstack/mcp": "workspace:*",
    "@wrongstack/tui": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
