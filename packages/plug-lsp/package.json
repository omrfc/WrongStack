{
  "name": "@wrongstack/plug-lsp",
  "version": "0.9.20",
  "license": "MIT",
  "description": "WrongStack plugin that exposes Language Server Protocol tools.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WrongStack/WrongStack.git",
    "directory": "packages/plug-lsp"
  },
  "homepage": "https://github.com/WrongStack/WrongStack#readme",
  "bugs": "https://github.com/WrongStack/WrongStack/issues",
  "author": "ECOSTACK TECHNOLOGY OU",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "wrongstack-lsp-setup": "./dist/setup.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "setup": "node ./dist/setup.js",
    "typecheck": "pnpm --filter @wrongstack/tools run build && tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@wrongstack/tools": "workspace:*",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "peerDependencies": {
    "@wrongstack/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@wrongstack/core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
